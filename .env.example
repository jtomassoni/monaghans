# Database
DATABASE_URL=postgresql://user:password@localhost:5432/monaghans

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Authentication - Admin Users
# Format: ADMIN_USER='{"username":"admin","password":"password"}' or ADMIN_USERS='[{"username":"admin1","password":"pass1"}]'
ADMIN_USER=
ADMIN_USERS=

# Authentication - Owner Users
# Format: OWNER_USER='{"username":"owner","password":"password"}' or OWNER_USERS='[{"username":"owner1","password":"pass1"}]'
OWNER_USER=
OWNER_USERS=

# reCAPTCHA Configuration
# Get keys from: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key_here
RECAPTCHA_SECRET_KEY=your_secret_key_here

# Feature Flags (optional)
ENABLE_ONLINE_ORDERING=false
ENABLE_SOCIAL_POSTING=false

# Stripe (optional - for online ordering payments)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Facebook/Instagram (optional - for social posting)
FACEBOOK_PAGE_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Resend (optional — private dining form staff notifications)
# https://resend.com
#
# RESEND_FROM must use an address @ a domain you verify in Resend (DNS). You do not need a real inbox —
# noreply@… is fine. With a display name, use plain words only (letters, numbers, spaces; no @, commas, or quotes). Example:
#   RESEND_FROM="Event Space at Monaghans <noreply@monaghansbarandgrilldenver.com>"
#
# Optional: if From is noreply@…, set Reply-To to the owner’s real inbox so “Reply” in the mail client goes there:
#   RESEND_REPLY_TO=owner@gmail.com
#
# On Vercel Preview, add these to the Preview environment too (or they will not send).
RESEND_API_KEY=
RESEND_FROM=
# RESEND_REPLY_TO=

# Resend webhook signing secret (dashboard → Webhooks → your endpoint → Signing Secret).
# Required to record "validation email opened" in the app when you enable open tracking on the domain.
# Webhook URL: https://<your-domain>/api/webhooks/resend — subscribe to `email.opened`.
RESEND_WEBHOOK_SECRET=

# Site URL for email links (verify links, admin deep links). Also used by NextAuth.
# - Local: http://localhost:3000
# - Vercel Preview: optional — if unset, the app uses https:// + VERCEL_URL (your *.vercel.app deployment).
# - Production: your canonical public URL, e.g. https://www.monaghansbarandgrilldenver.com
# NEXTAUTH_URL=https://www.example.com
